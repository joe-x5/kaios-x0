{"version":"1.1.0","name":"Paint IT","description":"A simple and fun drawing app for KaiOS. Snap a photo and sketch over it, or start from a blank canvas.","type":"web","launch_path":"/index.html","cursor":false,"icons":{"56":"/icons/56.png","112":"/icons/112.png"},"developer":{"name":"shifat100","url":"https://shifat100.xtgem.com"},"locales":{"en-US":{"name":"Paint IT","description":"A simple and fun Snap n Sketch drawing app for KaiOS. Snap a photo and sketch over it, or start from a blank canvas."},"zh-CN":{"name":"快照素描","description":"一款简单有趣的KaiOS绘图应用。拍摄照片并在其上素描，或从空白画布开始。"},"pt-BR":{"name":"Paint IT","description":"Um aplicativo de desenho simples e divertido para KaiOS. Tire uma foto e desenhe sobre ela, ou comece de uma tela em branco."},"it":{"name":"Scatta e Disegna","description":"Un'app di disegno semplice e divertente per KaiOS. Scatta una foto e disegnaci sopra, o inizia da una tela bianca."}},"default_locale":"en-US","permissions":{"camera":{"description":"Required to take photos to use as a background for your sketches."},"device-storage:pictures":{"access":"createonly","description":"Required to save your drawings to the device's Pictures gallery."},"storage":{"description":"Required to save drawings and settings within the app for later use."},"mobiledata":{"description":"Required for showing advertisements to support the app."},"activities":{"description":"Required to allow closing the application with the back key."}},"orientation":"portrait-primary","fullscreen":"false"}